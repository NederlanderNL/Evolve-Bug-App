# Turso database connection (create a free database at https://turso.tech)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Passcode required to add/edit/delete bugs and notes.
# Change this to whatever you want your staff editor to use.
EDIT_PASSCODE=EvolveBugReporter

# Comma-separated list of staff names allowed to vote on suggestions.
# Matching is case-insensitive. If you leave this unset, voting is open to
# any name typed in — set this before deploying for real.
VOTE_WHITELIST=Steve,Anna,Mike
