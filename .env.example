# Turso database connection (create a free database at https://turso.tech)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Discord OAuth app (create one at https://discord.com/developers/applications)
# In your Discord app: OAuth2 -> add a redirect URL of
#   http://localhost:3000/api/auth/callback/discord       (for local preview)
#   https://your-vercel-domain.vercel.app/api/auth/callback/discord  (for production)
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# NextAuth needs a random secret to sign session tokens. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-random-string

# Only needed in production if Vercel doesn't auto-detect it -- your deployed
# site's URL, e.g. https://evolve-bug-tracker.vercel.app
NEXTAUTH_URL=

# Comma-separated Discord user IDs (the numeric "snowflake", not username)
# who should automatically become Owner the first time they sign in.
# Get yours: Discord Settings -> Advanced -> enable Developer Mode, then
# right-click your profile picture anywhere -> Copy User ID.
OWNER_DISCORD_IDS=123456789012345678
