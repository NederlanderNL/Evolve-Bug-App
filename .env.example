# Turso database connection (create a free database at https://turso.tech)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Discord bot used ONLY to read bug reports from a forum channel — this is
# separate from any login system. Create one at
# https://discord.com/developers/applications -> New Application -> Bot tab
# -> Reset Token (copy it).
DISCORD_BOT_TOKEN=your-discord-bot-token

# The ID(s) of the Forum channel(s) where players post bug reports (each
# forum post = one bug report thread). If you have more than one bug-report
# channel, separate the IDs with commas, e.g. "111111,222222". Right-click
# a channel in Discord (Developer Mode must be on) -> Copy Channel ID.
DISCORD_BUG_FORUM_CHANNEL_ID=your-forum-channel-id

# Your server's ID, needed to also catch currently-open (non-archived)
# threads. Right-click your server icon -> Copy Server ID.
DISCORD_GUILD_ID=your-server-id
